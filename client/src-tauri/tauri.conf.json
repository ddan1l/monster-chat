{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Monster Chat",
  "version": "0.1.0",
  "identifier": "online.megamonster.chat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Monster Chat",
        "width": 380,
        "height": 700,
        "minWidth": 320,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://localhost:* wss: http://ipc.localhost https://ipc.localhost; img-src 'self' data:; object-src 'none'",
      "dangerousDisableAssetCspModification": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwQzdDNzkyRTc1MEVDRTMKUldUajdGRG5rc2ZIRUt0dXZEbno2QitqUDJMWnpoMXZWczZHclJQQjkzSWZnQUFWZDF6cTBvN20K",
      "endpoints": [
        "https://megamonster.chat/api/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
