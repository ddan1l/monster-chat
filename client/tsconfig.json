{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "@shared/*": ["./src/shared/*"],
            "@entities/*": ["./src/entities/*"],
            "@features/*": ["./src/features/*"],
            "@widgets/*": ["./src/widgets/*"],
            "@pages/*": ["./src/pages/*"],
            "@app/*": ["./src/app/*"]
        }
    },
    "include": ["src/**/*", "env.d.ts"]
}
